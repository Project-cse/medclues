# API — PC Wi-Fi IPv4 from `ipconfig` (not 127.0.0.1). Backend must use --host 0.0.0.0
EXPO_PUBLIC_API_URL=http://10.91.38.59:5000

# Firebase — copy VITE_FIREBASE_* from frontend/.env (same mediclues-e39db project)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=mediclues-e39db.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=mediclues-e39db
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=mediclues-e39db.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=675557370566
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google — Web client ID (Firebase → Auth → Google → Web SDK)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Google — Android OAuth client (REQUIRED on phone — see GOOGLE_SIGNIN.md)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
