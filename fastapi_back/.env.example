# MEDCLUES Backend — copy to .env and fill values (never commit .env)

# Core
DEBUG=true
PORT=5000
CURRENCY=INR

# JWT (required when DEBUG=false: min 32 chars, random — NOT "greatstack")
# Generate: openssl rand -base64 48
JWT_SECRET=
# Optional separate refresh signing secret (defaults to JWT_SECRET)
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (required in production)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# CORS (production) — comma-separated origins
# Example: https://medclues.onrender.com,https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Google OAuth — for social login idToken verification
# Use Firebase Web client ID(s), comma-separated for multiple
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
# Allow email-only social login without idToken (default: true in DEBUG, false in production)
SOCIAL_LOGIN_ALLOW_LEGACY=

# Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret from Razorpay Dashboard → Webhooks (for POST /api/payments/webhook)
RAZORPAY_WEBHOOK_SECRET=

# Email (Brevo or Gmail SMTP)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_APP_NAME=
EMAIL_USER=
EMAIL_APP_PASSWORD=

# Agora video
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# AI (optional)
GEMINI_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=

# Telegram bot (@medcluesBot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=medcluesBot
TELEGRAM_BOT_ENABLED=false

# MediChain external bot (optional — do not expose DB URL to this service)
MEDICHAIN_BOT_BASE_URL=
MEDICHAIN_BOT_API_KEY=
MEDICHAIN_BOT_PASSWORD=
